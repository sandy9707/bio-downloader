# Resend API Key for sending emails (obtain from https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# Default email sender address (must use a verified domain in Resend)
MAIL_FROM=YourAppName <no-reply@auth.yourdomain.com>

# Secure random secret for hashing verification codes before saving in Redis
PASSWORD_RESET_SECRET=some_long_random_and_secure_hmac_secret_key_here
