# Deployment Server Target Host
DEPLOY_SERVER=username@your_server_ip

# Backend Application Configuration
BACKEND_BASE_URL=http://your_server_ip:13000

# Redis Database Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=5

# Epay Gateway Configuration
EPAY_API_URL=https://zpayz.cn
EPAY_PID=your_epay_pid_here
EPAY_KEY=your_epay_key_here

# Speedup Clash Subscription Config
DEVELOPER_SUBSCRIBE_URL=https://subbind.yeyeziblog.eu.org/speedup?token=your_token_here

# Resend Email Integration
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=BioDownloader <no-reply@auth.yeyeziblog.eu.org>

# Security Secrets
ADMIN_SECRET=biodl_admin_2026
PASSWORD_RESET_SECRET=biodl_password_reset_secret_default_2026
